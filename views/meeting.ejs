<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meetingo</title>
  <link rel="stylesheet" href="/styles/index.css">

  <style>
    video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 10px;
    }

    /* uniform video cards */
    .video-box {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(12px);
      border-radius: 14px;
      overflow: hidden;
      min-height: 300px;
    }

    /* grid fix */
    .maindiv {
      grid-auto-rows: 300px;
    }

    /* controls */
    .control-bar {
      backdrop-filter: blur(12px);
      background: rgba(90, 50, 180, 0.6);
    }

    .control-btn {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.15);
      transition: 0.2s;
    }

    .control-btn:hover {
      background: rgba(255,255,255,0.3);
      transform: scale(1.05);
    }

    .end-call {
      background: #e53935;
    }

    .end-call:hover {
      background: #c62828;
    }
  </style>
</head>

<body class="bg-gradient-to-br from-purple-600 via-indigo-600 to-purple-700 min-h-screen flex flex-col">

<!-- Meet ID -->
<div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 text-white text-sm bg-white/10 px-5 py-2 rounded-full backdrop-blur-md flex gap-3 items-center shadow">
  <span id="user-id"><%= id %></span>
  <button id="copyBtn" class="text-purple-200 hover:text-white text-xs">Copy</button>
</div>

<!-- Video Grid -->
<div class="maindiv flex-1 grid gap-6 p-6 mt-20
  grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">

  <div class="video-box">
    <video class="mystream" autoplay playsinline muted></video>
  </div>

</div>

<!-- Controls -->
<div class="control-bar fixed bottom-6 left-1/2 -translate-x-1/2 flex gap-6 px-6 py-3 rounded-full shadow-xl z-50">

  <button class="control-btn" id="micBtn"></button>

  <button class="control-btn" id="cameraBtn"></button>

  <button class="control-btn end-call" id="hangupBtn"></button>

</div>

<script src="https://cdn.socket.io/4.4.0/socket.io.min.js"></script>
<script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>

<script>
  const id = <%- JSON.stringify(id) %>;
  const host = <%- JSON.stringify(host) %>;
</script>

<script type="module" src="/javascript/meeting.js"></script>

</body>
</html>