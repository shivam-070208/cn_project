<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meetingo</title>
  <link rel="stylesheet" href="/styles/index.css">

  <style>
    :root {
      color-scheme: light;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at top left, rgba(168, 85, 247, 0.18), transparent 30%),
        radial-gradient(circle at top right, rgba(99, 102, 241, 0.18), transparent 26%),
        linear-gradient(180deg, #6d28d9 0%, #4f46e5 48%, #7c3aed 100%);
      color: #0f172a;
    }

    video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 10px;
    }

    /* uniform video cards */
    .video-box {
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(14px);
      border: 1px solid rgba(148, 163, 184, 0.24);
      border-radius: 18px;
      overflow: hidden;
      min-height: 300px;
      width: min(100%, var(--card-size, 360px));
      max-width: var(--card-size, 360px);
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      justify-self: center;
    }

    /* grid fix */
    .maindiv {
      grid-auto-rows: 300px;
      width: min(100%, 1400px);
      margin: 0 auto;
      place-items: center;
      place-content: center;
      justify-items: center;
      align-content: center;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }

    /* controls */
    .control-bar {
      backdrop-filter: blur(18px);
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(148, 163, 184, 0.2);
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.12);
    }

    .control-btn {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #e2e8f0;
      transition: 0.2s;
    }

    .control-btn:hover {
      background: #cbd5e1;
      transform: scale(1.05);
    }

    .end-call {
      background: #ef4444;
    }

    .end-call:hover {
      background: #dc2626;
    }

    .room-chip {
      background: rgba(255,255,255,0.78);
      border: 1px solid rgba(148, 163, 184, 0.22);
      color: #0f172a;
    }

    .room-chip button {
      color: #334155;
    }
  </style>
</head>

<body class="min-h-screen flex flex-col">

<!-- Meet ID -->
<div class="room-chip fixed top-4 left-1/2 -translate-x-1/2 z-50 text-sm px-5 py-2 rounded-full backdrop-blur-md flex gap-3 items-center shadow">
  <span id="user-id"><%= id %></span>
  <button id="copyBtn" class="text-purple-200 hover:text-white text-xs">Copy</button>
</div>

<!-- Video Grid -->
<div class="maindiv flex-1 grid gap-6 p-6 pt-20 pb-28">

  <div class="video-box">
    <video class="mystream" autoplay playsinline muted></video>
  </div>

</div>

<!-- Controls -->
<div class="control-bar fixed bottom-6 left-1/2 -translate-x-1/2 flex gap-6 px-6 py-3 rounded-full shadow-xl z-50">

  <button class="control-btn" id="micBtn"></button>

  <button class="control-btn" id="cameraBtn"></button>

  <button class="control-btn end-call" id="hangupBtn"></button>

</div>

<script src="https://cdn.socket.io/4.4.0/socket.io.min.js"></script>
<script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>

<script>
  const id = <%- JSON.stringify(id) %>;
  const host = <%- JSON.stringify(host) %>;
</script>

<script type="module" src="/javascript/meeting.js"></script>

</body>
</html>